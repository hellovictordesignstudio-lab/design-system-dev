{
  "name": "@design-system/core",
  "version": "1.0.0",
  "description": "Professional Design System with React 18, TypeScript, and Styled Components",
  "homepage": "https://hellovictordesignstudio-lab.github.io/design-system",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "tsc --emitDeclarationOnly && rollup -c",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "predeploy": "npm run build-storybook",
    "deploy": "gh-pages -d storybook-static",
    "tokens": "style-dictionary build --config style-dictionary.config.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "lucide-react": "^0.446.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "styled-components": "^6.1.13"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.2",
    "@storybook/addon-a11y": "^8.3.5",
    "@storybook/addon-docs": "^8.3.5",
    "@storybook/addon-essentials": "^8.3.5",
    "@storybook/addon-interactions": "^8.3.5",
    "@storybook/addon-links": "^8.3.5",
    "@storybook/addon-themes": "^8.3.5",
    "@storybook/manager-api": "^8.3.5",
    "@storybook/react": "^8.3.5",
    "@storybook/react-vite": "^8.3.5",
    "@storybook/theming": "^8.3.5",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@types/styled-components": "^5.1.34",
    "@vitejs/plugin-react": "^4.3.2",
    "gh-pages": "^6.2.0",
    "storybook": "^8.3.5",
    "style-dictionary": "^4.2.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.8"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
